// ============================================================
//                     HELPER FUNCTIONS
// ============================================================
function log10(x){
return log(x)/2.302585092994046;
}
function pointInPolygon(px,py,xs,ys,n){
inside=false;
j=n-1;
for(i=0;i<n;i++){
xi=xs[i];yi=ys[i];
xj=xs[j];yj=ys[j];
intersect=((yi>py)!=(yj>py))&&
(px<(xj-xi)*(py-yi)/(yj-yi+1e-12)+xi);
if(intersect)inside=!inside;
j=i;
}
return inside;
}
function rectHitsPolygon(rx,ry,rw,rh,xs,ys,n){
if(pointInPolygon(rx,ry,xs,ys,n))return true;
if(pointInPolygon(rx+rw,ry,xs,ys,n))return true;
if(pointInPolygon(rx,ry+rh,xs,ys,n))return true;
if(pointInPolygon(rx+rw,ry+rh,xs,ys,n))return true;
if(pointInPolygon(rx+rw/2,ry+rh/2,xs,ys,n))return true;
return false;
}

