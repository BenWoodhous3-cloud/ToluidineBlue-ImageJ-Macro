for (s=1; s<=3; s++){
setSlice(s);
run("Measure");
val[s - 1] = getResult("Mean", nResults-1);
}
run("Select None");
whiteMean=(val[0]+val[1]+val[2])/3.0;
for (s=1; s<=3; s++) {
setSlice(s);
scale=whiteMean/maxOf(val[s-1], 1);
run("Multiply...", "value=" + scale);
}
run("Convert Stack to RGB");
rename(ti + "-corrected");
selectWindow("rgbstk-temp");
close();
print("White balance complete.");
print("Background mean intensity: " + d2s(whiteMean, 2));

// ============================================================
//             DEFINE POLYGON & VISUAL MASKING
// ============================================================
bgPolyDefined=false;
setTool("polygon");
waitForUser("DRAW a POLYGON defining the BACKGROUND REGION to IGNORE, then click OK.\nThis region will be excluded from ROI and tile sampling.");
if (selectionType() == -1){
bgPolyDefined = false;
print("No background polygon defined.");
}else{
bgPolyDefined=true;
getSelectionCoordinates(bgPolyX, bgPolyY);
for(k=0;k<bgPolyX.length;k++){
bgPolyX[k]=floor(bgPolyX[k]);
bgPolyY[k]=floor(bgPolyY[k]);
}
bgPolyN=bgPolyX.length;
Overlay.addSelection();
run("Properties...", "stroke=3 color=cyan");
Overlay.show();
}

// ============================================================
//            OPTICAL DENSITY of BACKGROUND
// ============================================================
whiteMeanClamp=maxOf(whiteMean,1);
whiteOD=0;
whiteOD_255=log10(255.0/whiteMeanClamp);

// ============================================================
//            EXCLUSION RECTANGLES
// ============================================================
setTool(0);
waitForUser("DRAW a RECTANGLE for the LOWER exclusion region, then click OK.");
excludeDefined1=true;
if (selectionType()==-1){
excludeDefined1=false;
print("No first exclusion region defined.");
}else{
getSelectionBounds(exclX1, exclY1, exclW1, exclH1);
print("First exclusion region: (" + exclX1 + "," + exclY1 + "), size = " + exclW1 + "x" + exclH1 + " px");
Overlay.addSelection();
run("Properties...", "stroke=3 color=red");
Overlay.show();
}
setTool(0);
waitForUser("DRAW a RECTANGLE for the UPPER exclusion region, then click OK.\nIf none, press Cancel.");
excludeDefined2 = true;
if (selectionType()==-1){
excludeDefined2 = false;
print("No second exclusion region defined.");
}else{
getSelectionBounds(exclX2, exclY2, exclW2, exclH2);
print("Second exclusion region: (" + exclX2 + "," + exclY2 + "), size = " + exclW2 + "x" + exclH2 + " px");
Overlay.addSelection();
run("Properties...", "stroke=3 color=orange");
Overlay.show();
}
if(!excludeDefined1 && !excludeDefined2)
print("Continuing without exclusion rectangles.");

// ============================================================
//                  GRAYSCALE & ROI SETUP
// ============================================================
setTool(0);
waitForUser("DRAW a RECTANGLE around the cartilage/sample ROI, then click OK.");
if(selectionType()==-1) exit("You must draw a rectangular cartilage ROI.");
originalTitle=getTitle();
getSelectionBounds(roiX, roiY, roiW, roiH);
run("Duplicate...", "title=Gray_Work");
selectWindow("Gray_Work");
run("8-bit");
rename("Gray_ROI");
makeRectangle(0, 0, roiW, roiH);
run("Set Measurements...", "mean redirect=None decimal=3");

// ============================================================
//          CONVERT POLYGON/EXCLUSIONS TO ROI COORDINATES
// ============================================================
if(bgPolyDefined){
for(k=0; k<bgPolyN;k++){
bgPolyX[k]=bgPolyX[k]-roiX;
bgPolyY[k]=bgPolyY[k]-roiY;
}
}
if(excludeDefined1){
exclX1=exclX1-roiX;
exclY1=exclY1-roiY;
if(exclX1<0){exclW1=exclW1+exclX1;exclX1=0;}
if(exclY1<0){exclH1=exclH1+exclY1;exclY1=0;}
if(exclX1+exclW1>roiW)exclW1=roiW-exclX1;
if(exclY1+exclH1>roiH)exclH1=roiH-exclY1;
if(exclW1<=0||exclH1<=0)excludeDefined1=false;
}
if(excludeDefined2){
exclX2=exclX2-roiX;
exclY2=exclY2-roiY;
if(exclX2<0){exclW2=exclW2+exclX2;exclX2=0;}
if(exclY2<0){exclH2=exclH2+exclY2;exclY2=0;}
if(exclX2+exclW2>roiW)exclW2=roiW-exclX2;
if(exclY2+exclH2>roiH)exclH2=roiH-exclY2;
if(exclW2<=0||exclH2<=0)excludeDefined2=false;
}

// ============================================================
//                      GRAY_ROI_VIS
// ============================================================
