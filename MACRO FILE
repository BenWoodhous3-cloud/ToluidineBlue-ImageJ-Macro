if (bgPolyDefined) {
makeSelection("polygon", bgPolyX, bgPolyY);
run("Invert");
Overlay.addSelection();
run("Properties...", "stroke=3 color=cyan");
Overlay.show();
}
selectWindow("Gray_ROI");
displayWin = "Gray_ROI_VIS";

// ============================================================
//                   GLOBAL ROI MEASUREMENT
// ============================================================
sum=0;
sumSq=0;
count=0;
excludedBg=0;
for(y=0;y<roiH;y++){
for(x=0;x<roiW;x++){
if(excludeDefined1 && x >= exclX1 && x < exclX1 + exclW1 && y >= exclY1 && y < exclY1 + exclH1)
continue;
if(excludeDefined2 && x >= exclX2 && x < exclX2 + exclW2 && y >= exclY2 && y < exclY2 + exclH2)
continue;
if(bgPolyDefined && pointInPolygon(x, y, bgPolyX, bgPolyY, bgPolyN)) {
excludedBg++;
continue;
}
v=getPixel(x,y);
sum +=v;
sumSq +=v*v;
count++;
}
}
if(count==0) exit("Global ROI contains no valid pixels after exclusions.");
meanROI=sum/count;
varInt=(sumSq-count*meanROI*meanROI)/maxOf(count-1,1);
sdInt_ROI=sqrt(maxOf(varInt,0));
meanClamp=maxOf(meanROI,1);
globalOD=log10(whiteMeanClamp/meanClamp);
sdOD_ROI=(log10(whiteMeanClamp/maxOf(meanROI-sdInt_ROI,1))-
log10(whiteMeanClamp/maxOf(meanROI+sdInt_ROI,1)))/2;

// ============================================================
//                        TILE ROIs
// ============================================================
existingRows=nResults;
if(existingRows==0){
rowStart=0;
print("Results table empty - starting at row 0.");
}else{
rowStart = existingRows;
}
selectWindow("Gray_ROI");
getDimensions(W,H,ch,sl,fr);
countTiles=0;
tries=0;
tileX=newArray(samples);
tileY=newArray(samples);
if(isOpen("ROI Manager")==0) run("ROI Manager...");
existingROIs=roiManager("count");
setBatchMode(true);
while (countTiles < samples && tries < samples * triesFactor) {
tries++;
x=floor(random()*(W-tileWidth));
y=floor(random()*(H-tileHeight));
if(x<spacing||y<spacing||(x+tileWidth+spacing)>W||(y+tileHeight+spacing)>H)
continue;
overlapsExcl=false;
if(excludeDefined1){
if(!(x+tileWidth<=exclX1||x>=exclX1+exclW1||y+tileHeight<=exclY1||y>=exclY1+exclH1))
overlapsExcl=true;
}
if(excludeDefined2){
if(!(x+tileWidth<=exclX2||x>=exclX2+exclW2||y+tileHeight<=exclY2||y>=exclY2+exclH2))
overlapsExcl=true;
}
if(overlapsExcl)continue;
if(bgPolyDefined && rectHitsPolygon(x,y,tileWidth,tileHeight,bgPolyX,bgPolyY,bgPolyN))
continue;
overlap=0;
for(i=0;i<countTiles;i++){
if(!(x+tileWidth+spacing<=tileX[i]||
tileX[i]+tileWidth+spacing<=x||
y+tileHeight+spacing<=tileY[i]||
tileY[i]+tileHeight+spacing<=y)){
overlap=1;
break;
}
}
if(overlap==1)continue;
selectWindow("Gray_ROI");
makeRectangle(x,y,tileWidth,tileHeight);
getStatistics(area,mean,min,max,std);
OD=log10(whiteMeanClamp/maxOf(mean,1));
newIndex=existingRows+countTiles;
setResult("Tile#",newIndex,countTiles+1);
setResult("Sample",newIndex,sampleID);
setResult("Run",newIndex,runID);
setResult("Analysis",newIndex,analysisType);
setResult("Zone",newIndex,zoneID);
setResult("X",newIndex,x);
setResult("Y",newIndex,y);
setResult("Mean Intensity",newIndex,mean);
setResult("Mean OD",newIndex,OD);
tileX[countTiles]=x;
tileY[countTiles]=y;
roiManager("Add");
roiManager("Select",roiManager("count")-1);
roiManager("Rename", sampleID + " " + runID + " " + zoneID + " TILE " + (countTiles + 1));
countTiles++;
}
setBatchMode(false);
run("Select None");
selectWindow(displayWin);
roiManager("Show All");
print("Total tiles collected: " + countTiles + " (after " + tries + " attempts)");

// ============================================================
//                    AGGREGATE TILE STATS
// ============================================================
rows=nResults;
tileRows=rows-rowStart;
if(tileRows<=0)exit("No valid tiles collected.");
sumInt=0;
sumOD=0;
sumSqInt=0;
sumSqOD=0;
valid=0;
for(i=rowStart;i<rows;i++){
tnum=getResult("Tile#",i);
if(!isNaN(tnum)){
intensity=getResult("Mean Intensity",i);
if(!isNaN(intensity)){
sumInt += intensity;
sumOD += getResult("Mean OD",i);
valid++;
}
}
}
if(valid==0)exit("No valid tiles to aggregate.");
meanIntensity_tiles=sumInt/valid;
meanOD_tiles=sumOD/valid;
for(i=rowStart;i<rows;i++){
tnum=getResult("Tile#",i);
if(!isNaN(tnum)){
intensity=getResult("Mean Intensity",i);
if(!isNaN(intensity)) {
odVal=getResult("Mean OD",i);
sumSqInt += pow(intensity-meanIntensity_tiles,2);
sumSqOD += pow(odVal-meanOD_tiles,2);
}
}
}
if(valid>1){
sdInt_tiles=sqrt(sumSqInt/(valid-1));
sdOD_tiles=sqrt(sumSqOD/(valid-1));
}else{
sdInt_tiles=0;
sdOD_tiles=0;
}
Array.getStatistics(val,minW,maxW,meanW,stdW);
sdInt_white=stdW;
sdOD_white=0;

